// SPDX-License-Identifier: MIT
//
// Module map for the WireGuard C library. Consumed by Swift via
// `import WireGuardCore` once the xcframework is dropped into an
// Xcode project (or SwiftPM target).
//
// Only the I/O-agnostic wg_session.h surface is exposed. Swift does
// not need the noise/cookie/allowedips primitives directly — those
// are implementation details of libwg.a.

module WireGuardCore {
    header "wg_session.h"
    export *
    link "wg"
    link "swift_crypto"
}
